{
  "rewrites": [
    {
      "source": "/api/catalog/:path*",
      "destination": "https://phone-shop-backend.vercel.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://phone-shop-backend.vercel.app/Uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
